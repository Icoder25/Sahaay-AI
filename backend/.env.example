# Core
APP_ENV=development
DATABASE_URL=sqlite:///./sahaay.db
CORS_ORIGINS=http://localhost:3000

# Supabase Auth. Never expose the service-role key to a client.
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_AUDIENCE=authenticated
# Optional password-based SQLAlchemy connection when DATABASE_URL is blank
SUPABASE_DB_PASSWORD=
SUPABASE_DB_HOST=aws-0-ap-northeast-1.pooler.supabase.com
SUPABASE_DB_PORT=6543

# Optional AI integrations (disabled when blank)
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-5
EXA_API_KEY=
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ENABLE_VOICE=false

# Optional notifications/background work (stored-only/in-process when blank)
# Paste a one-line Firebase service account JSON object, not a file path.
FIREBASE_CREDENTIALS_JSON=
REDIS_URL=
CELERY_ALWAYS_EAGER=false
