# Core
APP_ENV=development
DATABASE_URL=
CORS_ORIGINS=http://localhost:3000

# Supabase data access. Never expose the service-role key to a client.
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
# Used to build DATABASE_URL when it is blank
SUPABASE_DB_PASSWORD=
SUPABASE_DB_HOST=aws-0-ap-northeast-1.pooler.supabase.com
SUPABASE_DB_PORT=6543

# Optional AI integrations (disabled when blank)
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-5
EXA_API_KEY=
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
ENABLE_VOICE=true

# Firebase authentication and optional FCM notifications
# Paste a one-line service-account JSON object.
FIREBASE_CREDENTIALS_JSON=
FIREBASE_PROJECT_ID=

# Optional background work
REDIS_URL=
CELERY_ALWAYS_EAGER=false
