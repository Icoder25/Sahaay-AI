# Sahaay frontend — copy to repo root as `.replit` for the Frontend Repl
# Monorepo layout: commands `cd frontend` first.
entrypoint = "frontend/src/app/page.tsx"
modules = ["nodejs-20"]
hidden = ["**/node_modules", "**/.next", "frontend/node_modules", "frontend/.next"]

# Dev: Run button (do NOT set NODE_ENV=production here — breaks next dev)
run = "cd frontend && npm install && npx next dev -H 0.0.0.0 -p 3000"

[nix]
channel = "stable-24_05"

[deployment]
deploymentTarget = "cloudrun"
build = ["sh", "-c", "cd frontend && npm ci && npm run build"]
run = ["sh", "-c", "cd frontend && npx next start -H 0.0.0.0 -p 3000"]

[[ports]]
localPort = 3000
externalPort = 80

[env]
# Set in Replit Secrets (required for Deploy build):
# NEXT_PUBLIC_API_BASE_URL=https://<backend-repl>.replit.app
